# Copy this file to server/.env for local development.

# Enable local-only debug features such as POST /debug/reset-seed.
DEBUG=true

# Optional: enable LLM phrasing for newly created active nudges.
OPENAI_API_KEY=

# Optional: override the default OpenAI model used for phrasing and meal analysis.
OPENAI_MODEL=gpt-5-mini

# Optional: request timeout in seconds for phrasing calls.
PHRASING_TIMEOUT_SECONDS=3

# Optional: request timeout in seconds for meal-photo analysis calls.
MEAL_ANALYSIS_TIMEOUT_SECONDS=5

# Optional: override the SQLite database location.
# Prefer an absolute path if you change this.
# DATABASE_PATH=/absolute/path/to/nudge.db